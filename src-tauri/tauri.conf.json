{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GrokDesk",
  "version": "0.1.5",
  "identifier": "com.grokdesk.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GrokDesk",
        "label": "main",
        "width": 1440,
        "height": 1024,
        "minWidth": 980,
        "minHeight": 680,
        "center": true,
        "decorations": false,
        "resizable": true,
        "transparent": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "A desktop workspace for Grok Build",
    "longDescription": "GrokDesk presents the official Grok Build ACP runtime in a polished native task, plan, tool, diff, and terminal workspace.",
    "resources": {
      "icons/icon.ico": "GrokDesk-v0.1.5.ico"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/installer-hooks.nsh"
      }
    }
  }
}
